# Copy to .env.local and fill in your values.
# .env.local is gitignored and loaded automatically by direnv and the launch scripts.

# Required: admin user created in OpenClaw containers for SSH/troubleshooting
PODCLAW_ADMIN_USER=yourname
PODCLAW_SSH_KEY="ssh-ed25519 AAAA..."

# Optional: Incus remote (omit to target the local host)
# PODCLAW_REMOTE=your-remote

# Optional: default container name (omit for auto-generated oc-exp-<timestamp>)
# PODCLAW_CONTAINER_NAME=my-openclaw

# Optional: override Incus profile names (defaults shown)
# PODCLAW_PROFILE_BRIDGED=bridged
# PODCLAW_PROFILE_NESTING=docker
